{
  "$schema": "https://raw.githubusercontent.com/fallow-rs/fallow/main/schema.json",
  "entry": [
    "src/index.{ts,tsx,js,jsx}",
    "src/main.{ts,tsx,js,jsx}"
  ],
  "duplicates": {
    // Keep duplicate detection available for reports without failing this scoped dead-code cleanup.
    "enabled": false,
    "minOccurrences": 3,
    "threshold": 100
  },
  "health": {
    // Keep health metrics informational; broad complexity refactors are tracked separately.
    "maxCyclomatic": 999,
    "maxCognitive": 999,
    "maxCrap": 999
  },
  "rules": {
    "unused-dependencies": "warn"
  },
  "ignoreExports": [
    {
      "file": "src/shared/skills.ts",
      "exports": ["*"]
    },
    {
      "file": "src/shared/types.ts",
      "exports": ["*"]
    },
    {
      "file": "src/execution/subagent-executor.ts",
      "exports": ["*"]
    },
    {
      "file": "src/agents/agents.ts",
      "exports": ["discoverAgentsAll"]
    }
  ]
}
