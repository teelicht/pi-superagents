{
  "name": "@teelicht/pi-superagents",
  "version": "0.9.1",
  "description": "Pi extension for Superpowers workflows: recon, research, implementation, review, and debug",
  "author": "Thomas Lichtenecker",
  "license": "MIT",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/teelicht/pi-superagents.git"
  },
  "homepage": "https://github.com/teelicht/pi-superagents#readme",
  "bugs": {
    "url": "https://github.com/teelicht/pi-superagents/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "pi-package",
    "pi",
    "pi-coding-agent",
    "subagents",
    "ai",
    "agents",
    "cli",
    "superpowers"
  ],
  "bin": {
    "pi-superagents": "install.mjs"
  },
  "files": [
    "src/",
    "scripts/",
    "agents/",
    "docs/",
    "default-config.json",
    "config.example.json",
    "*.mjs",
    "README.md",
    "CHANGELOG.md"
  ],
  "scripts": {
    "prepublishOnly": "npm test",
    "debug:pi-local": "node --experimental-strip-types ./scripts/local-extension-install.ts",
    "qa": "biome check --write && tsc -noEmit && npm run test:all",
    "lint": "biome check --write",
    "typecheck": "tsc --noEmit",
    "test": "npm run test:unit",
    "test:unit": "node --experimental-strip-types --test test/unit/*.test.ts",
    "test:integration": "node --experimental-strip-types --import ./test/support/register-loader.mjs --test test/integration/*.test.ts",
    "test:e2e": "node --experimental-strip-types --import ./test/support/register-loader.mjs --test test/e2e/*.test.ts",
    "test:all": "npm run test:unit && npm run test:integration && npm run test:e2e"
  },
  "pi": {
    "extensions": [
      "./src/extension/index.ts"
    ]
  },
  "peerDependencies": {
    "@earendil-works/pi-agent-core": "*",
    "@earendil-works/pi-ai": "*",
    "@earendil-works/pi-coding-agent": "*",
    "@earendil-works/pi-tui": "*",
    "typebox": "*"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.13",
    "@earendil-works/pi-agent-core": "^0.75.3",
    "@earendil-works/pi-ai": "^0.75.3",
    "@earendil-works/pi-coding-agent": "^0.75.3",
    "@earendil-works/pi-tui": "^0.75.3",
    "@types/node": "^25.6.0",
    "@vitest/coverage-v8": "^4.1.4",
    "typebox": "^1.1.24",
    "typescript": "^6.0.3",
    "vitest": "^4.1.4"
  }
}
