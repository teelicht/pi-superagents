{
  "name": "@teelicht/pi-superagents",
  "version": "0.3.0",
  "description": "Pi extension for Superpowers workflows: recon, research, implementation, review, and debug",
  "author": "Thomas Lichtenecker, Nico Bailon",
  "license": "MIT",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nicobailon/pi-superagents.git"
  },
  "homepage": "https://github.com/nicobailon/pi-superagents#readme",
  "bugs": {
    "url": "https://github.com/nicobailon/pi-superagents/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "pi-package",
    "pi",
    "pi-coding-agent",
    "subagents",
    "ai",
    "agents",
    "cli",
    "superpowers"
  ],
  "bin": {
    "pi-superagents": "install.mjs"
  },
  "files": [
    "src/",
    "scripts/",
    "agents/",
    "docs/",
    "default-config.json",
    "config.example.json",
    "*.mjs",
    "README.md",
    "CHANGELOG.md"
  ],
  "scripts": {
    "prepublishOnly": "npm test",
    "debug:pi-local": "node --experimental-transform-types ./scripts/local-extension-install.ts",
    "test": "npm run test:unit",
    "test:unit": "node --experimental-strip-types --test test/unit/*.test.ts",
    "test:integration": "node --experimental-transform-types --import ./test/support/register-loader.mjs --test test/integration/*.test.ts",
    "test:e2e": "node --experimental-transform-types --import ./test/support/register-loader.mjs --test test/e2e/*.test.ts",
    "test:all": "npm run test:unit && npm run test:integration && npm run test:e2e"
  },
  "pi": {
    "extensions": [
      "./src/extension/index.ts",
      "./src/extension/notify.ts"
    ]
  },
  "peerDependencies": {
    "@mariozechner/pi-agent-core": "*",
    "@mariozechner/pi-ai": "*",
    "@mariozechner/pi-coding-agent": "*",
    "@mariozechner/pi-tui": "*",
    "@sinclair/typebox": "*"
  },
  "devDependencies": {
    "@marcfargas/pi-test-harness": "^0.5.0",
    "@mariozechner/pi-agent-core": "^0.65.0",
    "@mariozechner/pi-ai": "^0.65.0",
    "@mariozechner/pi-coding-agent": "^0.65.0",
    "@mariozechner/pi-tui": "^0.66.1",
    "@sinclair/typebox": "^0.34.49"
  }
}
